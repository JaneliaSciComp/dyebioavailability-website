{
  "dataUrl": "https://s3.janelia.org/lavis-lab/Dye_Bioavailability_images/Website/zarrcade.csv",
  "title": "Dye Bioavailability",
  "data": {
    "delimiter": ",",
    "pathColumn": "File Path",
    "thumbnailColumn": "Thumbnail",
    "fullSizeColumn": "MIP"
  },
  "display": {
    "pageSize": 50,
    "titleTemplate": "<font color='0000ff'>{DAPI (blue)}</font> <font color='00b300'>{FITC (green)}</font> <font color='ff8c1a'>{CY3 (orange)}</font> <font color='db00db'>{CY5 (magenta)}</font>",
    "hideColumns": [
      "File Path",
      "DAPI (blue)",
      "FITC (green)",
      "CY3 (orange)",
      "CY5 (magenta)",
      "Thumbnail",
      "MIP"
    ]
  },
  "filters": [
    { "column": "Species",   "label": "Species" },
    { "column": "Tissue",    "label": "Tissue" },
    { "column": "Pulse Dye", "label": "Pulse Dye" },
    { "column": "Chase Dye", "label": "Chase Dye" }
  ],
  "viewers": [
    {
      "name": "Avivator",
      "icon": "vizarr_logo.png",
      "urlTemplate": "https://janeliascicomp.github.io/viv/?image_url={ENCODED_URL}",
      "enabled": true
    },
    {
      "name": "Neuroglancer",
      "icon": "neuroglancer.png",
      "urlTemplate": "https://neuroglancer-demo.appspot.com/#!{\"layers\":[{\"name\":\"{NAME}\",\"source\":\"{URL}\",\"type\":\"auto\"}],\"selectedLayer\":{\"visible\":true,\"layer\":\"{NAME}\"},\"layout\":\"4panel-alt\"}",
      "enabled": true
    }
  ],
  "branding": {
    "headerBg": "#000",
    "footerBg": "#000",
    "headerLeftLogo": {
      "src": "branding/T3-Logo.png",
      "href": "https://www.janelia.org/project-team/tool-translation-team-t3",
      "alt": "T3 Lab"
    },
    "headerRightLogo": {
      "src": "branding/HHMI_Janelia_Logo_Black_Background.png",
      "href": "https://www.janelia.org",
      "alt": "HHMI Janelia"
    },
    "footer": {
      "left": {
        "html": "© 2026 Howard Hughes Medical Institute"
      },
      "right": {
        "html": "<a href=\"https://www.hhmi.org/privacy-policy\">Privacy Policy &amp; Cookie Notice</a>"
      }
    }
  }
}
